{
  "name": "sf.admin.react.template",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "scripts": {
    "start": "cross-env VITE_VERSION=$npm_package_version vite --host",
    "build": "cross-env VITE_VERSION=$npm_package_version vite build",
    "lint": "eslint .",
    "ts:check": "tsc --noEmit",
    "fsd:check": "steiger ./src",
    "test": "vitest run",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json}\""
  },
  "dependencies": {
    "antd": "^6.3.7",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "effector": "^23.3.0",
    "effector-forms": "2.0.0-next.1",
    "effector-react": "^23.3.0",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.17.21",
    "oidc-client-ts": "^3.1.0",
    "patronum": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "react-transition-group": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@feature-sliced/eslint-config": "^0.1.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-eslint": "^10.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-effector": "^0.18.0",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "gitlog": "^5.1.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsonfile": "^6.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "sass-embedded": "^1.83.4",
    "scss": "^0.2.4",
    "steiger": "^0.5.5",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint",
      "prettier --write",
      "bash -c 'tsc --noEmit'",
      "bash -c 'steiger ./src'"
    ]
  }
}
